          <attvalue for="1" value="Pensamiento complejo (Morin)" />
          <attvalue for="2" value="Edgar Morin" />
          <attvalue for="3" value="Lógica donde los efectos retroactúan sobre las causas, generando bucles autorrreguladores y transformativos." />
