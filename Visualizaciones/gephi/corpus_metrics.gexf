      <node id="trinidad-cognitiva-cerebro-mente-cultura" label="Trinidad cognitiva (cerebro-mente-cultura)">
        <viz:color r="122" g="46" b="46" a="1.0" />
        <viz:size value="17.61567600260062" />
        <attvalues>
          <attvalue for="0" value="morin" />
          <attvalue for="1" value="Pensamiento complejo (Morin)" />
          <attvalue for="2" value="Edgar Morin" />
          <attvalue for="3" value="Triangulación inseparable donde el cerebro produce la mente, la mente externaliza en cultura, la cultura moldea el cerebro." />
          <attvalue for="4" value="7" />
          <attvalue for="5" value="9.0" />
          <attvalue for="6" value="0.0380783800130031" />
          <attvalue for="7" value="0.33707865168539325" />
          <attvalue for="8" value="0.10541624564422632" />
          <attvalue for="9" value="0.0" />
