          <attvalue for="2" value="Edgar Morin" />
          <attvalue for="3" value="Esfera de ideas, símbolos y significados que emerge de la actividad mental colectiva y se vuelve autónoma respecto a los individuos." />
          <attvalue for="4" value="5" />
          <attvalue for="5" value="8.0" />
          <attvalue for="6" value="0.0029616838980134857" />
