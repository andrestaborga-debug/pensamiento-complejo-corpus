      <node id="mito-y-pensamiento-simbolico" label="Mito y pensamiento simbólico">
        <viz:color r="122" g="46" b="46" a="1.0" />
        <viz:size value="10.583981740844486" />
        <attvalues>
          <attvalue for="0" value="morin" />
          <attvalue for="1" value="Pensamiento complejo (Morin)" />
          <attvalue for="2" value="Edgar Morin" />
          <attvalue for="3" value="Narrativas que organizan el sentido profundo de una cultura y la cual la razón pura no puede penetrar ni reemplazar." />
          <attvalue for="4" value="5" />
          <attvalue for="5" value="8.0" />
          <attvalue for="6" value="0.002919908704222429" />
