      <node id="homo-sapiens-demens" label="Homo sapiens/demens">
        <viz:color r="122" g="46" b="46" a="1.0" />
        <viz:size value="10.199750312109863" />
        <attvalues>
          <attvalue for="0" value="morin" />
          <attvalue for="1" value="Pensamiento complejo (Morin)" />
          <attvalue for="2" value="Edgar Morin" />
          <attvalue for="3" value="Ser humano caracterizado por la inseparabilidad radical entre razón (sapiens) e irracionalidad (demens), sin que una supere a la otra." />
          <attvalue for="4" value="5" />
          <attvalue for="5" value="9.0" />
          <attvalue for="6" value="0.0009987515605493131" />
          <attvalue for="7" value="0.24861878453038674" />
