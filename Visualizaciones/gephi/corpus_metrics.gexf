      <node id="bien-pensar" label="Bien pensar">
        <viz:color r="122" g="46" b="46" a="1.0" />
        <viz:size value="12.433357084601852" />
        <attvalues>
          <attvalue for="0" value="morin" />
          <attvalue for="1" value="Pensamiento complejo (Morin)" />
          <attvalue for="2" value="Edgar Morin" />
          <attvalue for="3" value="Ejercicio permanente del pensamiento reflexivo, integrador y ético que anticipa consecuencias y permanece abierto a la complejidad." />
          <attvalue for="4" value="5" />
          <attvalue for="5" value="6.0" />
