      <node id="trinidad-humana-individuo-sociedad-especie" label="Trinidad humana (individuo-sociedad-especie)">
        <viz:color r="122" g="46" b="46" a="1.0" />
        <viz:size value="13.889260209815397" />
        <attvalues>
          <attvalue for="0" value="morin" />
          <attvalue for="1" value="Pensamiento complejo (Morin)" />
          <attvalue for="2" value="Edgar Morin" />
          <attvalue for="3" value="Articulación de tres dimensiones donde cada una depende y se realiza en las otras dos sin subordinación jerárquica." />
          <attvalue for="4" value="7" />
          <attvalue for="5" value="11.0" />
          <attvalue for="6" value="0.019446301049076988" />
          <attvalue for="7" value="0.28938906752411575" />
          <attvalue for="8" value="0.11398215256208527" />
          <attvalue for="9" value="0.0" />
