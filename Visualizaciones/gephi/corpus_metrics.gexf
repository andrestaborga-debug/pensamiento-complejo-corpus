        <viz:size value="19.445941413445272" />
        <attvalues>
          <attvalue for="0" value="morin" />
          <attvalue for="1" value="Pensamiento complejo (Morin)" />
          <attvalue for="2" value="Edgar Morin" />
          <attvalue for="3" value="Inteligencia empática que integra el conocimiento intelectual con la empatía y el reconocimiento del otro en su dignidad." />
