          <attvalue for="1" value="Pensamiento complejo (Morin)" />
          <attvalue for="2" value="Edgar Morin" />
          <attvalue for="3" value="Dinámica donde caos, orden, interacción e organización se retroalimentan generando sistemas vivos e impredecibles." />
          <attvalue for="4" value="8" />
