        <attvalues>
          <attvalue for="0" value="morin" />
          <attvalue for="1" value="Pensamiento complejo (Morin)" />
          <attvalue for="2" value="Edgar Morin" />
          <attvalue for="3" value="Ética de la solidaridad: reconocimiento de la dignidad de todos, compromiso con justicia y transformación social." />
