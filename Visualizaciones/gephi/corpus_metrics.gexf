        </attvalues>
      </node>
      <node id="idea-como-ser-viviente" label="Idea (como ser viviente)">
        <viz:color r="122" g="46" b="46" a="1.0" />
        <viz:size value="10.251631708560547" />
        <attvalues>
          <attvalue for="0" value="morin" />
          <attvalue for="1" value="Pensamiento complejo (Morin)" />
          <attvalue for="2" value="Edgar Morin" />
          <attvalue for="3" value="Las ideas no son esencias atemporales sino organismos vivos que nacen, se reproducen, mutan, compiten y mueren." />
          <attvalue for="4" value="5" />
          <attvalue for="5" value="8.0" />
          <attvalue for="6" value="0.0012581585428027373" />
          <attvalue for="7" value="0.2535211267605634" />
          <attvalue for="8" value="0.06264299668855482" />
          <attvalue for="9" value="0.0" />
          <attvalue for="10" value="3" />
        </attvalues>
      </node>
      <node id="incertidumbre" label="Incertidumbre">
        <viz:color r="122" g="46" b="46" a="1.0" />
        <viz:size value="10.397840700991175" />
        <attvalues>
          <attvalue for="0" value="morin" />
          <attvalue for="1" value="Pensamiento complejo (Morin)" />
          <attvalue for="2" value="Edgar Morin" />
          <attvalue for="3" value="Realidad irreducible: el futuro es abierto, el conocimiento es parcial, ningún sistema es completamente predecible." />
          <attvalue for="4" value="6" />
          <attvalue for="5" value="10.0" />
          <attvalue for="6" value="0.0019892035049558724" />
          <attvalue for="7" value="0.2647058823529412" />
          <attvalue for="8" value="0.12509835937277305" />
          <attvalue for="9" value="0.0" />
          <attvalue for="10" value="3" />
        </attvalues>
      </node>
      <node id="maquina-viviente" label="Máquina viviente">
        <viz:color r="122" g="46" b="46" a="1.0" />
        <viz:size value="10.771041707620597" />
        <attvalues>
          <attvalue for="0" value="morin" />
          <attvalue for="1" value="Pensamiento complejo (Morin)" />
          <attvalue for="2" value="Edgar Morin" />
          <attvalue for="3" value="Paradoja: ser vivo que no es máquina mecánica pero sí es productor de orden, información y propósito." />
          <attvalue for="4" value="7" />
          <attvalue for="5" value="12.0" />
          <attvalue for="6" value="0.0038552085381029855" />
          <attvalue for="7" value="0.3125" />
          <attvalue for="8" value="0.21405644381159722" />
          <attvalue for="9" value="0.0" />
          <attvalue for="10" value="2" />
        </attvalues>
      </node>
      <node id="metodo" label="Método">
        <viz:color r="122" g="46" b="46" a="1.0" />
        <viz:size value="12.806479274644069" />
        <attvalues>
          <attvalue for="0" value="morin" />
          <attvalue for="1" value="Pensamiento complejo (Morin)" />
          <attvalue for="2" value="Edgar Morin" />
          <attvalue for="3" value="Vía de pensamiento que respeta la singularidad de lo que estudia sin pretender leyes universales que ignoren el contexto." />
          <attvalue for="4" value="7" />
          <attvalue for="5" value="9.0" />
          <attvalue for="6" value="0.014032396373220343" />
          <attvalue for="7" value="0.27522935779816515" />
