        <viz:size value="17.026858971772434" />
        <attvalues>
          <attvalue for="0" value="morin" />
          <attvalue for="1" value="Pensamiento complejo (Morin)" />
          <attvalue for="2" value="Edgar Morin" />
          <attvalue for="3" value="Organización que se autogenera manteniendo intercambio permanente con su entorno, del cual no puede escindirse." />
