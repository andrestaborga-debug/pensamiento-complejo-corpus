      <node id="conocimiento-del-conocimiento" label="Conocimiento del conocimiento">
        <viz:color r="122" g="46" b="46" a="1.0" />
        <viz:size value="20.54680656096166" />
        <attvalues>
          <attvalue for="0" value="morin" />
