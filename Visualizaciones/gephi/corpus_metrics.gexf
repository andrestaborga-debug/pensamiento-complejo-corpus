        <viz:size value="14.848011628690191" />
        <attvalues>
          <attvalue for="0" value="morin" />
          <attvalue for="1" value="Pensamiento complejo (Morin)" />
          <attvalue for="2" value="Edgar Morin" />
          <attvalue for="3" value="Reconocimiento de que todos los humanos comparten un destino común en un planeta único, base de una solidaridad global." />
          <attvalue for="4" value="9" />
          <attvalue for="5" value="14.0" />
