          <attvalue for="1" value="Pensamiento complejo (Morin)" />
          <attvalue for="2" value="Edgar Morin" />
          <attvalue for="3" value="Dependencia recíproca e inseparable entre los seres vivos y su entorno, constitutiva de toda existencia." />
