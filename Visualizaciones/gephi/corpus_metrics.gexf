        <attvalues>
          <attvalue for="0" value="morin" />
          <attvalue for="1" value="Pensamiento complejo (Morin)" />
          <attvalue for="2" value="Edgar Morin" />
          <attvalue for="3" value="Proceso por el cual un sistema se autogenera mientras está inseparablemente acoplado a su entorno, transformándolo y siendo transformado." />
