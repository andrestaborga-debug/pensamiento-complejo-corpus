      <node id="orden---desorden" label="Orden / Desorden">
        <viz:color r="122" g="46" b="46" a="1.0" />
        <viz:size value="11.765156340802385" />
        <attvalues>
          <attvalue for="0" value="morin" />
          <attvalue for="1" value="Pensamiento complejo (Morin)" />
          <attvalue for="2" value="Edgar Morin" />
          <attvalue for="3" value="Pareja irreducible que, en diálogo, es fuente de toda organización y creatividad." />
          <attvalue for="4" value="6" />
          <attvalue for="5" value="9.0" />
          <attvalue for="6" value="0.008825781704011926" />
