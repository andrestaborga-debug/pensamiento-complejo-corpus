    <nodes>
      <node id="antropo-etica" label="Antropo-ética">
        <viz:color r="122" g="46" b="46" a="1.0" />
        <viz:size value="25.172559348157385" />
        <attvalues>
          <attvalue for="0" value="morin" />
          <attvalue for="1" value="Pensamiento complejo (Morin)" />
          <attvalue for="2" value="Edgar Morin" />
          <attvalue for="3" value="Ética que reconoce la responsabilidad del ser humano hacia sí mismo, hacia los otros y hacia la vida toda." />
