      </node>
      <node id="autopoiesis" label="Autopoiesis">
        <viz:color r="74" g="107" b="60" a="1.0" />
        <viz:size value="28.616038859080017" />
        <attvalues>
          <attvalue for="0" value="autopoiesis" />
          <attvalue for="1" value="Autopoiesis" />
          <attvalue for="2" value="Humberto Maturana &amp; Francisco Varela" />
          <attvalue for="3" value="El proceso por el cual un sistema vivo produce continuamente los componentes que lo constituyen como tal sistema, manteniéndose como unidad autónoma." />
          <attvalue for="4" value="14" />
          <attvalue for="5" value="16.0" />
          <attvalue for="6" value="0.09308019429540008" />
          <attvalue for="7" value="0.36585365853658536" />
          <attvalue for="8" value="0.12045832322340427" />
          <attvalue for="9" value="0.0" />
          <attvalue for="10" value="5" />
        </attvalues>
      </node>
      <node id="clausura-operacional" label="Clausura operacional">
        <viz:color r="74" g="107" b="60" a="1.0" />
        <viz:size value="17.382216677163395" />
        <attvalues>
          <attvalue for="0" value="autopoiesis" />
          <attvalue for="1" value="Autopoiesis" />
          <attvalue for="2" value="Humberto Maturana &amp; Francisco Varela" />
          <attvalue for="3" value="Propiedad de un sistema cuyas operaciones se cierran sobre sí mismas: cada cambio del sistema genera otros cambios dentro del mismo sistema, no acciones sobre algo externo." />
          <attvalue for="4" value="8" />
          <attvalue for="5" value="10.0" />
          <attvalue for="6" value="0.03691108338581697" />
          <attvalue for="7" value="0.33210332103321033" />
          <attvalue for="8" value="0.06973305430488135" />
          <attvalue for="9" value="0.0" />
          <attvalue for="10" value="5" />
        </attvalues>
      </node>
      <node id="acoplamiento-estructural" label="Acoplamiento estructural">
        <viz:color r="74" g="107" b="60" a="1.0" />
        <viz:size value="20.930603438695073" />
        <attvalues>
          <attvalue for="0" value="autopoiesis" />
          <attvalue for="1" value="Autopoiesis" />
          <attvalue for="2" value="Humberto Maturana &amp; Francisco Varela" />
          <attvalue for="3" value="Historia de cambios estructurales recíprocos entre dos sistemas autopoiéticos —o entre un sistema y su medio— que se mantienen sin desintegrarse." />
          <attvalue for="4" value="10" />
          <attvalue for="5" value="13.0" />
          <attvalue for="6" value="0.05465301719347537" />
          <attvalue for="7" value="0.3358208955223881" />
          <attvalue for="8" value="0.08403817113361348" />
          <attvalue for="9" value="0.0" />
          <attvalue for="10" value="5" />
        </attvalues>
      </node>
      <node id="deriva-natural" label="Deriva natural">
        <viz:color r="74" g="107" b="60" a="1.0" />
        <viz:size value="12.216749886996638" />
        <attvalues>
          <attvalue for="0" value="autopoiesis" />
          <attvalue for="1" value="Autopoiesis" />
          <attvalue for="2" value="Humberto Maturana &amp; Francisco Varela" />
          <attvalue for="3" value="La evolución como deriva sin meta: los linajes de seres vivos se transforman siguiendo los caminos que su acoplamiento estructural permite, no los que la «selección» optimiza." />
          <attvalue for="4" value="5" />
          <attvalue for="5" value="5.0" />
          <attvalue for="6" value="0.011083749434983185" />
          <attvalue for="7" value="0.29508196721311475" />
          <attvalue for="8" value="0.031917800971599825" />
          <attvalue for="9" value="0.0" />
          <attvalue for="10" value="7" />
        </attvalues>
      </node>
      <node id="todo-hacer-es-conocer" label="Todo hacer es conocer">
        <viz:color r="74" g="107" b="60" a="1.0" />
        <viz:size value="10.304429901367552" />
        <attvalues>
          <attvalue for="0" value="autopoiesis" />
          <attvalue for="1" value="Autopoiesis" />
          <attvalue for="2" value="Humberto Maturana &amp; Francisco Varela" />
          <attvalue for="3" value="El acto de vivir es ya un acto de conocer: no hay distancia entre la actividad biológica y la cognitiva en un ser vivo." />
          <attvalue for="4" value="3" />
          <attvalue for="5" value="4.0" />
          <attvalue for="6" value="0.0015221495068377645" />
          <attvalue for="7" value="0.30405405405405406" />
          <attvalue for="8" value="0.03506238730171855" />
          <attvalue for="9" value="0.0" />
          <attvalue for="10" value="5" />
        </attvalues>
      </node>
      <node id="enaccion" label="Enacción">
        <viz:color r="107" g="74" b="60" a="1.0" />
        <viz:size value="13.187875028697222" />
        <attvalues>
          <attvalue for="0" value="embodied" />
          <attvalue for="1" value="Cognicion encarnada" />
          <attvalue for="2" value="Francisco Varela, Evan Thompson &amp; Eleanor Rosch" />
          <attvalue for="3" value="Aproximación a la cognición que reemplaza la metáfora representacionista por la idea de que conocer es enactuar — hacer emerger — un mundo en la acción del organismo." />
          <attvalue for="4" value="6" />
          <attvalue for="5" value="7.0" />
          <attvalue for="6" value="0.015939375143486114" />
          <attvalue for="7" value="0.3157894736842105" />
          <attvalue for="8" value="0.03847109873634815" />
          <attvalue for="9" value="0.0" />
          <attvalue for="10" value="2" />
        </attvalues>
      </node>
      <node id="accion-encarnada" label="Acción encarnada">
        <viz:color r="107" g="74" b="60" a="1.0" />
        <viz:size value="15.383236383170363" />
        <attvalues>
          <attvalue for="0" value="embodied" />
          <attvalue for="1" value="Cognicion encarnada" />
          <attvalue for="2" value="Francisco Varela, Evan Thompson &amp; Eleanor Rosch" />
          <attvalue for="3" value="El estudio de la cognición no como recuperación de un mundo dado ni como proyección de uno interno, sino como acción de un cuerpo concreto en una historia concreta." />
          <attvalue for="4" value="8" />
          <attvalue for="5" value="9.0" />
          <attvalue for="6" value="0.026916181915851815" />
          <attvalue for="7" value="0.3157894736842105" />
          <attvalue for="8" value="0.038068638107975374" />
          <attvalue for="9" value="0.0" />
          <attvalue for="10" value="2" />
        </attvalues>
      </node>
      <node id="sin-yo" label="Sin yo (Selfless mind)">
        <viz:color r="107" g="74" b="60" a="1.0" />
        <viz:size value="18.839088885134274" />
        <attvalues>
          <attvalue for="0" value="embodied" />
          <attvalue for="1" value="Cognicion encarnada" />
          <attvalue for="2" value="Francisco Varela, Evan Thompson &amp; Eleanor Rosch" />
          <attvalue for="3" value="La tesis de que la mente no es propiedad de un yo unitario, sino una sociedad heterogénea de procesos sin centro — articulada con la idea budista de no-yo (anātman)." />
          <attvalue for="4" value="6" />
          <attvalue for="5" value="7.0" />
          <attvalue for="6" value="0.04419544442567136" />
          <attvalue for="7" value="0.3284671532846715" />
          <attvalue for="8" value="0.03884824177930793" />
          <attvalue for="9" value="0.0" />
          <attvalue for="10" value="6" />
        </attvalues>
      </node>
      <node id="camino-medio" label="Camino medio">
        <viz:color r="107" g="74" b="60" a="1.0" />
        <viz:size value="11.653594371814243" />
        <attvalues>
          <attvalue for="0" value="embodied" />
          <attvalue for="1" value="Cognicion encarnada" />
          <attvalue for="2" value="Francisco Varela, Evan Thompson &amp; Eleanor Rosch" />
          <attvalue for="3" value="Vía intermedia entre objetivismo (creer en un fundamento absoluto) y nihilismo (negar todo fundamento): aprender a vivir sin fundamento sin que eso implique disolución." />
          <attvalue for="4" value="3" />
          <attvalue for="5" value="5.0" />
          <attvalue for="6" value="0.00826797185907122" />
          <attvalue for="7" value="0.26785714285714285" />
          <attvalue for="8" value="0.03174130620373951" />
          <attvalue for="9" value="0.0" />
          <attvalue for="10" value="6" />
        </attvalues>
      </node>
      <node id="hacer-camino-al-andar" label="Hacer camino al andar">
        <viz:color r="107" g="74" b="60" a="1.0" />
        <viz:size value="14.24334654517514" />
        <attvalues>
          <attvalue for="0" value="embodied" />
          <attvalue for="1" value="Cognicion encarnada" />
          <attvalue for="2" value="Francisco Varela, Evan Thompson &amp; Eleanor Rosch" />
          <attvalue for="3" value="Imagen para la cognición encarnada: no hay un camino dado que se recorre, sino un caminar que va trazando su camino a medida que avanza, condicionado por lo ya andado pero sin meta prefijada." />
          <attvalue for="4" value="5" />
          <attvalue for="5" value="6.0" />
          <attvalue for="6" value="0.021216732725875702" />
          <attvalue for="7" value="0.33088235294117646" />
          <attvalue for="8" value="0.04429595484241127" />
          <attvalue for="9" value="0.0" />
          <attvalue for="10" value="6" />
        </attvalues>
      </node>
      <node id="cuerpo-propio" label="Cuerpo propio">
        <viz:color r="107" g="74" b="60" a="1.0" />
        <viz:size value="12.272611901208583" />
        <attvalues>
          <attvalue for="0" value="embodied" />
          <attvalue for="1" value="Cognicion encarnada" />
          <attvalue for="2" value="Maurice Merleau-Ponty" />
          <attvalue for="3" value="Mi cuerpo no es un objeto entre objetos sino el sujeto mismo de la percepción: el medio a través del cual hay un mundo para mí." />
          <attvalue for="4" value="6" />
          <attvalue for="5" value="8.0" />
          <attvalue for="6" value="0.011363059506042914" />
          <attvalue for="7" value="0.30303030303030304" />
          <attvalue for="8" value="0.03133187978669848" />
          <attvalue for="9" value="0.0" />
          <attvalue for="10" value="2" />
        </attvalues>
      </node>
      <node id="esquema-corporal" label="Esquema corporal">
        <viz:color r="107" g="74" b="60" a="1.0" />
        <viz:size value="10.495211070057028" />
        <attvalues>
          <attvalue for="0" value="embodied" />
          <attvalue for="1" value="Cognicion encarnada" />
          <attvalue for="2" value="Maurice Merleau-Ponty" />
          <attvalue for="3" value="Sistema dinámico mediante el cual mi cuerpo se me presenta no como suma de partes sino como postura unificada en vista de una tarea actual o posible." />
          <attvalue for="4" value="4" />
          <attvalue for="5" value="5.0" />
          <attvalue for="6" value="0.0024760553502851438" />
          <attvalue for="7" value="0.2702702702702703" />
          <attvalue for="8" value="0.017556116718857075" />
          <attvalue for="9" value="0.0" />
          <attvalue for="10" value="2" />
        </attvalues>
      </node>
      <node id="intencionalidad-operante" label="Intencionalidad operante">
        <viz:color r="107" g="74" b="60" a="1.0" />
        <viz:size value="10.359786828148744" />
        <attvalues>
          <attvalue for="0" value="embodied" />
          <attvalue for="1" value="Cognicion encarnada" />
          <attvalue for="2" value="Maurice Merleau-Ponty" />
          <attvalue for="3" value="Forma pre-reflexiva de la intencionalidad: la unidad ya tejida del mundo y la vida que opera por debajo del juicio explícito, en deseos, evaluaciones, paisajes." />
          <attvalue for="4" value="4" />
          <attvalue for="5" value="6.0" />
          <attvalue for="6" value="0.001798934140743721" />
          <attvalue for="7" value="0.3" />
          <attvalue for="8" value="0.02985142486654344" />
          <attvalue for="9" value="0.0" />
          <attvalue for="10" value="2" />
        </attvalues>
      </node>
      <node id="cogito-tacito" label="Cogito tácito">
        <viz:color r="107" g="74" b="60" a="1.0" />
        <viz:size value="10.369809965315584" />
        <attvalues>
          <attvalue for="0" value="embodied" />
          <attvalue for="1" value="Cognicion encarnada" />
          <attvalue for="2" value="Maurice Merleau-Ponty" />
          <attvalue for="3" value="Presencia de sí a sí mismo anterior al lenguaje y a toda formulación: la subjetividad como vivencia silenciosa, no como pensamiento explícito." />
          <attvalue for="4" value="4" />
          <attvalue for="5" value="5.0" />
          <attvalue for="6" value="0.0018490498265779163" />
          <attvalue for="7" value="0.3082191780821918" />
          <attvalue for="8" value="0.02685715466367593" />
          <attvalue for="9" value="0.0" />
          <attvalue for="10" value="2" />
        </attvalues>
      </node>
      <node id="movimiento-generador-del-espacio" label="Movimiento generador del espacio">
        <viz:color r="107" g="74" b="60" a="1.0" />
        <viz:size value="10.288302063780085" />
        <attvalues>
          <attvalue for="0" value="embodied" />
          <attvalue for="1" value="Cognicion encarnada" />
          <attvalue for="2" value="Maurice Merleau-Ponty" />
          <attvalue for="3" value="El cuerpo no se desplaza dentro de un espacio pre-dado: el cuerpo en movimiento intencional es lo que genera el espacio mismo en que las cosas se sitúan." />
          <attvalue for="4" value="4" />
          <attvalue for="5" value="4.0" />
          <attvalue for="6" value="0.0014415103189004234" />
          <attvalue for="7" value="0.2616279069767442" />
          <attvalue for="8" value="0.011234536238161966" />
          <attvalue for="9" value="0.0" />
          <attvalue for="10" value="2" />
        </attvalues>
      </node>
      <node id="cerebro-predictivo" label="Cerebro predictivo">
        <viz:color r="107" g="60" b="91" a="1.0" />
        <viz:size value="10.009987515605493" />
        <attvalues>
          <attvalue for="0" value="predictive" />
          <attvalue for="1" value="Mente predictiva" />
          <attvalue for="2" value="Andy Clark" />
          <attvalue for="3" value="Tesis según la cual el cerebro no procesa información sensorial bottom-up: anticipa la entrada con expectativas top-down y solo procesa el error de predicción que queda." />
          <attvalue for="4" value="5" />
          <attvalue for="5" value="9.0" />
          <attvalue for="6" value="4.993757802746567e-05" />
          <attvalue for="7" value="0.2356020942408377" />
          <attvalue for="8" value="0.025366709592769637" />
          <attvalue for="9" value="0.0" />
          <attvalue for="10" value="5" />
        </attvalues>
      </node>
      <node id="error-de-prediccion" label="Error de predicción">
        <viz:color r="107" g="60" b="91" a="1.0" />
        <viz:size value="10.0" />
        <attvalues>
          <attvalue for="0" value="predictive" />
          <attvalue for="1" value="Mente predictiva" />
          <attvalue for="2" value="Andy Clark" />
          <attvalue for="3" value="Diferencia entre la entrada sensorial predicha por el cerebro y la efectivamente recibida. Es la única información que asciende por la jerarquía cortical: «sorpresa» que el sistema busca cancelar." />
          <attvalue for="4" value="3" />
          <attvalue for="5" value="5.0" />
          <attvalue for="6" value="0.0" />
          <attvalue for="7" value="0.2564102564102564" />
          <attvalue for="8" value="0.012800584482913078" />
          <attvalue for="9" value="0.0" />
          <attvalue for="10" value="5" />
        </attvalues>
      </node>
      <node id="procesamiento-jerarquico-predictivo" label="Procesamiento jerárquico predictivo">
        <viz:color r="107" g="60" b="91" a="1.0" />
        <viz:size value="10.0" />
        <attvalues>
          <attvalue for="0" value="predictive" />
          <attvalue for="1" value="Mente predictiva" />
          <attvalue for="2" value="Andy Clark" />
          <attvalue for="3" value="Arquitectura cortical donde cada nivel predice las entradas del nivel inferior y le envía sus predicciones top-down; el inferior solo le devuelve el error de predicción." />
          <attvalue for="4" value="3" />
          <attvalue for="5" value="5.0" />
          <attvalue for="6" value="0.0" />
          <attvalue for="7" value="0.2564102564102564" />
          <attvalue for="8" value="0.012800584482913078" />
          <attvalue for="9" value="0.0" />
          <attvalue for="10" value="5" />
        </attvalues>
      </node>
      <node id="energia-libre-variacional" label="Energía libre variacional">
        <viz:color r="107" g="60" b="91" a="1.0" />
        <viz:size value="22.675858687590342" />
        <attvalues>
          <attvalue for="0" value="predictive" />
          <attvalue for="1" value="Mente predictiva" />
          <attvalue for="2" value="Karl Friston" />
          <attvalue for="3" value="Cantidad termodinámico-informacional que un sistema autoorganizado debe minimizar para resistir la dispersión hacia el equilibrio. Cota superior de la sorpresa." />
          <attvalue for="4" value="9" />
          <attvalue for="5" value="11.0" />
          <attvalue for="6" value="0.06337929343795172" />
          <attvalue for="7" value="0.34220532319391633" />
          <attvalue for="8" value="0.06657831473273108" />
          <attvalue for="9" value="0.0" />
          <attvalue for="10" value="5" />
        </attvalues>
      </node>
      <node id="inferencia-activa" label="Inferencia activa">
        <viz:color r="107" g="60" b="91" a="1.0" />
        <viz:size value="11.278562885304458" />
        <attvalues>
          <attvalue for="0" value="predictive" />
          <attvalue for="1" value="Mente predictiva" />
          <attvalue for="2" value="Karl Friston" />
          <attvalue for="3" value="Acción concebida como minimización de la sorpresa: actúo sobre el ambiente para que las sensaciones que recibo coincidan con las que predigo." />
          <attvalue for="4" value="6" />
          <attvalue for="5" value="8.0" />
          <attvalue for="6" value="0.006392814426522293" />
          <attvalue for="7" value="0.2903225806451613" />
          <attvalue for="8" value="0.03472265016717002" />
          <attvalue for="9" value="0.0" />
          <attvalue for="10" value="5" />
        </attvalues>
      </node>
      <node id="ocasion-actual" label="Ocasión actual">
        <viz:color r="60" g="107" b="91" a="1.0" />
        <viz:size value="12.01194116569634" />
        <attvalues>
          <attvalue for="0" value="proceso" />
          <attvalue for="1" value="Filosofia del proceso (Whitehead)" />
          <attvalue for="2" value="Alfred North Whitehead" />
          <attvalue for="3" value="Unidad última de la realidad: no una cosa que dura sino un evento que se concreta. Las ocasiones actuales son los átomos del proceso, las únicas realidades finales." />
          <attvalue for="4" value="6" />
          <attvalue for="5" value="10.0" />
          <attvalue for="6" value="0.0100597058284817" />
          <attvalue for="7" value="0.30927835051546393" />
          <attvalue for="8" value="0.07052816433366889" />
          <attvalue for="9" value="0.0" />
          <attvalue for="10" value="6" />
        </attvalues>
      </node>
      <node id="prehension" label="Prehensión">
        <viz:color r="60" g="107" b="91" a="1.0" />
        <viz:size value="12.96232883498801" />
        <attvalues>
          <attvalue for="0" value="proceso" />
          <attvalue for="1" value="Filosofia del proceso (Whitehead)" />
          <attvalue for="2" value="Alfred North Whitehead" />
          <attvalue for="3" value="Acto por el cual una ocasión actual «toma en cuenta» otras ocasiones e incorpora sus formas, integrándolas como datos de su propio devenir. Operación constitutiva del proceso." />
          <attvalue for="4" value="5" />
          <attvalue for="5" value="8.0" />
          <attvalue for="6" value="0.014811644174940053" />
          <attvalue for="7" value="0.26865671641791045" />
          <attvalue for="8" value="0.04452059028065818" />
          <attvalue for="9" value="0.0" />
          <attvalue for="10" value="6" />
        </attvalues>
      </node>
      <node id="concrescencia" label="Concrescencia">
        <viz:color r="60" g="107" b="91" a="1.0" />
        <viz:size value="11.191778833880619" />
        <attvalues>
          <attvalue for="0" value="proceso" />
          <attvalue for="1" value="Filosofia del proceso (Whitehead)" />
          <attvalue for="2" value="Alfred North Whitehead" />
          <attvalue for="3" value="Proceso por el cual los muchos se hacen uno: las múltiples potencialidades del universo confluyen en la unidad concreta de una nueva ocasión actual." />
          <attvalue for="4" value="5" />
          <attvalue for="5" value="8.0" />
          <attvalue for="6" value="0.005958894169403092" />
          <attvalue for="7" value="0.24390243902439024" />
          <attvalue for="8" value="0.05350768831831588" />
          <attvalue for="9" value="0.0" />
          <attvalue for="10" value="6" />
        </attvalues>
      </node>
      <node id="creatividad" label="Creatividad">
        <viz:color r="60" g="107" b="91" a="1.0" />
        <viz:size value="13.251162568311603" />
        <attvalues>
          <attvalue for="0" value="proceso" />
          <attvalue for="1" value="Filosofia del proceso (Whitehead)" />
          <attvalue for="2" value="Alfred North Whitehead" />
          <attvalue for="3" value="Categoría de lo Último: el principio dinámico por el que los muchos se hacen uno y el uno se acrecienta en uno. No es una entidad: es la condición ontológica del devenir." />
          <attvalue for="4" value="6" />
          <attvalue for="5" value="8.0" />
          <attvalue for="6" value="0.016255812841558012" />
          <attvalue for="7" value="0.32727272727272727" />
          <attvalue for="8" value="0.07605195718147936" />
          <attvalue for="9" value="0.0" />
          <attvalue for="10" value="6" />
        </attvalues>
      </node>
      <node id="filosofia-del-organismo" label="Filosofía del organismo">
        <viz:color r="60" g="107" b="91" a="1.0" />
        <viz:size value="29.160996147893332" />
        <attvalues>
          <attvalue for="0" value="proceso" />
          <attvalue for="1" value="Filosofia del proceso (Whitehead)" />
          <attvalue for="2" value="Alfred North Whitehead" />
          <attvalue for="3" value="Nombre del sistema metafísico whiteheadiano: ontología en la que los entes últimos no son sustancias inertes sino organismos —procesos relacionales que se constituyen por sus relaciones con el universo entero." />
          <attvalue for="4" value="9" />
          <attvalue for="5" value="11.0" />
          <attvalue for="6" value="0.09580498073946665" />
          <attvalue for="7" value="0.3629032258064516" />
          <attvalue for="8" value="0.07484875307821753" />
          <attvalue for="9" value="0.0" />
          <attvalue for="10" value="6" />
        </attvalues>
      </node>
      <node id="informacion-integrada" label="Información integrada (Φ)">
        <viz:color r="91" g="60" b="107" a="1.0" />
        <viz:size value="16.484712823838066" />
        <attvalues>
          <attvalue for="0" value="iit" />
          <attvalue for="1" value="Informacion integrada (IIT)" />
          <attvalue for="2" value="Giulio Tononi" />
          <attvalue for="3" value="Cantidad que mide cuánta información un sistema genera por encima de sus partes. Para Tononi, es la consciencia: donde hay Φ &gt; 0, hay un cuanto de experiencia." />
          <attvalue for="4" value="6" />
          <attvalue for="5" value="8.0" />
          <attvalue for="6" value="0.03242356411919033" />
          <attvalue for="7" value="0.28753993610223644" />
          <attvalue for="8" value="0.019569316707344343" />
          <attvalue for="9" value="0.0" />
          <attvalue for="10" value="6" />
        </attvalues>
      </node>
      <node id="complejo-principal" label="Complejo principal">
        <viz:color r="91" g="60" b="107" a="1.0" />
        <viz:size value="10.292134831460674" />
        <attvalues>
          <attvalue for="0" value="iit" />
          <attvalue for="1" value="Informacion integrada (IIT)" />
          <attvalue for="2" value="Giulio Tononi" />
          <attvalue for="3" value="Subsistema con el valor máximo de Φ que no está incluido en otro mayor con Φ todavía más alto. Para la IIT, es la unidad concreta de la consciencia." />
          <attvalue for="4" value="3" />
          <attvalue for="5" value="4.0" />
          <attvalue for="6" value="0.0014606741573033705" />
          <attvalue for="7" value="0.2727272727272727" />
          <attvalue for="8" value="0.013302425478542301" />
          <attvalue for="9" value="0.0" />
          <attvalue for="10" value="6" />
        </attvalues>
      </node>
      <node id="universalismo-del-yo" label="Universalismo del yo (open individualism)">
        <viz:color r="107" g="91" b="60" a="1.0" />
        <viz:size value="13.166498226423322" />
        <attvalues>
          <attvalue for="0" value="panpsiquismo" />
          <attvalue for="1" value="Panpsiquismo" />
          <attvalue for="2" value="Arnold Zuboff" />
          <attvalue for="3" value="Tesis de que las fronteras aparentes entre los sujetos son ilusorias: la identidad personal se conserva a través de cualquier variación o multiplicación de cuerpo y mente. Hay un solo Yo que vive todas las experiencias." />
          <attvalue for="4" value="5" />
          <attvalue for="5" value="7.0" />
          <attvalue for="6" value="0.015832491132116603" />
          <attvalue for="7" value="0.2727272727272727" />
          <attvalue for="8" value="0.01982581764581126" />
          <attvalue for="9" value="0.0" />
          <attvalue for="10" value="6" />
        </attvalues>
      </node>
      <node id="panpsiquismo" label="Panpsiquismo">
        <viz:color r="107" g="91" b="60" a="1.0" />
        <viz:size value="10.224302954640033" />
        <attvalues>
          <attvalue for="0" value="panpsiquismo" />
          <attvalue for="1" value="Panpsiquismo" />
          <attvalue for="2" value="William Seager (ed.)" />
          <attvalue for="3" value="Tesis según la cual la consciencia es una propiedad fundamental y ubicua del mundo —no algo que emerge tarde de procesos no-conscientes, sino algo presente desde el nivel básico de la realidad." />
          <attvalue for="4" value="5" />
          <attvalue for="5" value="9.0" />
          <attvalue for="6" value="0.0011215147732001663" />
          <attvalue for="7" value="0.22332506203473945" />
          <attvalue for="8" value="0.015245099994168032" />
          <attvalue for="9" value="0.0" />
          <attvalue for="10" value="6" />
        </attvalues>
      </node>
      <node id="problema-de-la-combinacion" label="Problema de la combinación">
        <viz:color r="107" g="91" b="60" a="1.0" />
        <viz:size value="10.652819596419508" />
        <attvalues>
          <attvalue for="0" value="panpsiquismo" />
          <attvalue for="1" value="Panpsiquismo" />
          <attvalue for="2" value="William Seager (ed.)" />
          <attvalue for="3" value="Si la consciencia es fundamental en sus constituyentes básicos, ¿cómo se combinan esas micro-consciencias para formar las macro-consciencias unificadas que conocemos? Es el desafío central que enfrenta cualquier panpsiquismo." />
          <attvalue for="4" value="4" />
          <attvalue for="5" value="6.0" />
          <attvalue for="6" value="0.003264097982097541" />
          <attvalue for="7" value="0.24861878453038674" />
          <attvalue for="8" value="0.008870714543203697" />
          <attvalue for="9" value="0.0" />
          <attvalue for="10" value="6" />
        </attvalues>
      </node>
      <node id="cosmopsicismo" label="Cosmopsicismo">
        <viz:color r="107" g="91" b="60" a="1.0" />
        <viz:size value="10.340328557557022" />
        <attvalues>
          <attvalue for="0" value="panpsiquismo" />
          <attvalue for="1" value="Panpsiquismo" />
          <attvalue for="2" value="William Seager (ed.)" />
          <attvalue for="3" value="Variante del panpsiquismo según la cual la consciencia fundamental no está en las partículas mínimas (panpsiquismo «de abajo») sino en el universo como un todo, del que las consciencias individuales son particularizaciones." />
          <attvalue for="4" value="4" />
          <attvalue for="5" value="7.0" />
          <attvalue for="6" value="0.0017016427877851097" />
          <attvalue for="7" value="0.27439024390243905" />
          <attvalue for="8" value="0.014575851272956295" />
          <attvalue for="9" value="0.0" />
          <attvalue for="10" value="6" />
        </attvalues>
      </node>
      <node id="pensamiento-de-la-complejidad" label="Pensamiento «de la Complejidad»">
        <viz:color r="139" g="107" b="58" a="1.0" />
        <viz:size value="16.163011900178674" />
        <attvalues>
          <attvalue for="0" value="social" />
          <attvalue for="1" value="Complejidad social" />
          <attvalue for="2" value="Pedro Luis Sotolongo Codina &amp; Carlos Jesús Delgado Díaz" />
          <attvalue for="3" value="Programa intelectual contemporáneo que reta el ideal clásico de racionalidad simplificadora y propone una racionalidad de la complejidad: pensar interacciones, redes, emergencia y devenir antes que objetos aislados." />
          <attvalue for="4" value="6" />
          <attvalue for="5" value="8.0" />
          <attvalue for="6" value="0.030815059500893367" />
          <attvalue for="7" value="0.30612244897959184" />
          <attvalue for="8" value="0.059317737509228516" />
          <attvalue for="9" value="0.0" />
          <attvalue for="10" value="8" />
        </attvalues>
      </node>
      <node id="ciencias-sociales-de-nuevo-tipo" label="Ciencias sociales de nuevo tipo">
        <viz:color r="139" g="107" b="58" a="1.0" />
        <viz:size value="11.731179993131965" />
        <attvalues>
          <attvalue for="0" value="social" />
          <attvalue for="1" value="Complejidad social" />
          <attvalue for="2" value="Pedro Luis Sotolongo Codina &amp; Carlos Jesús Delgado Díaz" />
          <attvalue for="3" value="Programa de reorganización epistemológica de las ciencias sociales latinoamericanas: recuperar el pathos crítico abandonado y construirlas desde el ideal complejo de racionalidad." />
          <attvalue for="4" value="5" />
          <attvalue for="5" value="8.0" />
          <attvalue for="6" value="0.008655899965659825" />
          <attvalue for="7" value="0.26548672566371684" />
          <attvalue for="8" value="0.06275104411500473" />
          <attvalue for="9" value="0.0" />
          <attvalue for="10" value="8" />
        </attvalues>
      </node>
      <node id="epistemologia-hermeneutica-segundo-orden" label="Epistemología hermenéutica de segundo orden">
        <viz:color r="139" g="107" b="58" a="1.0" />
        <viz:size value="15.281037306593596" />
        <attvalues>
          <attvalue for="0" value="social" />
          <attvalue for="1" value="Complejidad social" />
          <attvalue for="2" value="Pedro Luis Sotolongo Codina &amp; Carlos Jesús Delgado Díaz" />
          <attvalue for="3" value="Tercer tratamiento de la relación sujeto-objeto, posterior al objetivante y al fenomenológico: en lugar de desconectar uno de los polos, asume la mutua constitución de sujeto y objeto en una historia de prácticas." />
          <attvalue for="4" value="4" />
          <attvalue for="5" value="4.0" />
          <attvalue for="6" value="0.026405186532967986" />
          <attvalue for="7" value="0.32967032967032966" />
          <attvalue for="8" value="0.02998240111705565" />
          <attvalue for="9" value="0.0" />
          <attvalue for="10" value="8" />
        </attvalues>
      </node>
      <node id="dialogo-de-saberes" label="Diálogo de saberes">
        <viz:color r="139" g="107" b="58" a="1.0" />
        <viz:size value="10.522230244195434" />
        <attvalues>
          <attvalue for="0" value="social" />
          <attvalue for="1" value="Complejidad social" />
          <attvalue for="2" value="Pedro Luis Sotolongo Codina &amp; Carlos Jesús Delgado Díaz" />
          <attvalue for="3" value="Sustituir el «centrismo» eurocéntrico (y norteamericano) por un diálogo recíproco entre tradiciones de conocimiento: aprender del otro, reconocer que el otro tiene algo que enseñarnos." />
          <attvalue for="4" value="4" />
          <attvalue for="5" value="6.0" />
          <attvalue for="6" value="0.002611151220977174" />
          <attvalue for="7" value="0.2564102564102564" />
          <attvalue for="8" value="0.05089656082682863" />
          <attvalue for="9" value="0.0" />
          <attvalue for="10" value="8" />
        </attvalues>
      </node>
      <node id="transdisciplinariedad" label="Transdisciplinariedad">
        <viz:color r="139" g="107" b="58" a="1.0" />
        <viz:size value="10.40982862331177" />
        <attvalues>
          <attvalue for="0" value="social" />
          <attvalue for="1" value="Complejidad social" />
          <attvalue for="2" value="Pedro Luis Sotolongo Codina &amp; Carlos Jesús Delgado Díaz" />
          <attvalue for="3" value="No es la eliminación de las disciplinas sino su trascendencia: corpus de saber que cruzan los límites disciplinarios sin renunciar a sus aportes, articulándolos en torno a problemas que ninguna disciplina sola puede abordar." />
          <attvalue for="4" value="5" />
          <attvalue for="5" value="8.0" />
          <attvalue for="6" value="0.002049143116558847" />
          <attvalue for="7" value="0.25280898876404495" />
          <attvalue for="8" value="0.0613254718980946" />
          <attvalue for="9" value="0.0" />
          <attvalue for="10" value="8" />
        </attvalues>
      </node>
      <node id="ambiente-como-invencion" label="El ambiente como invención">
        <viz:color r="60" g="91" b="107" a="1.0" />
        <viz:size value="11.337884822903549" />
        <attvalues>
          <attvalue for="0" value="cybernetics" />
          <attvalue for="1" value="Cibernetica 2do orden" />
          <attvalue for="2" value="Heinz von Foerster" />
          <attvalue for="3" value="Tesis fundadora de la cibernética de segundo orden: el entorno tal como lo experimentamos no es algo dado «allá afuera» sino algo que cada organismo cognoscente construye —inventa— en el acto mismo de percibir." />
          <attvalue for="4" value="6" />
          <attvalue for="5" value="9.0" />
          <attvalue for="6" value="0.006689424114517746" />
          <attvalue for="7" value="0.30927835051546393" />
          <attvalue for="8" value="0.04702261432460244" />
          <attvalue for="9" value="0.0" />
          <attvalue for="10" value="5" />
        </attvalues>
      </node>
      <node id="codificacion-indiferenciada" label="Codificación indiferenciada">
        <viz:color r="60" g="91" b="107" a="1.0" />
        <viz:size value="11.282664711010858" />
        <attvalues>
          <attvalue for="0" value="cybernetics" />
          <attvalue for="1" value="Cibernetica 2do orden" />
          <attvalue for="2" value="Heinz von Foerster" />
          <attvalue for="3" value="Las células nerviosas no codifican la naturaleza física del estímulo que las gatilla, solo su cantidad. La cualidad —color, sonido, calor— no viene del mundo: emerge de la organización del sistema nervioso." />
          <attvalue for="4" value="4" />
          <attvalue for="5" value="6.0" />
          <attvalue for="6" value="0.006413323555054287" />
          <attvalue for="7" value="0.26785714285714285" />
          <attvalue for="8" value="0.02416017019977881" />
          <attvalue for="9" value="0.0" />
          <attvalue for="10" value="5" />
        </attvalues>
      </node>
      <node id="computar-la-realidad" label="Computar la realidad">
        <viz:color r="60" g="91" b="107" a="1.0" />
        <viz:size value="14.261172437918415" />
        <attvalues>
          <attvalue for="0" value="cybernetics" />
          <attvalue for="1" value="Cibernetica 2do orden" />
          <attvalue for="2" value="Heinz von Foerster" />
          <attvalue for="3" value="«Cognición» = computar descripciones de una realidad. Computar (com-putare: contemplar juntos) refiere cualquier operación que transforme, ordene o relacione entidades, no solo cálculo numérico." />
          <attvalue for="4" value="5" />
          <attvalue for="5" value="6.0" />
          <attvalue for="6" value="0.021305862189592076" />
          <attvalue for="7" value="0.3" />
          <attvalue for="8" value="0.029403565993856542" />
          <attvalue for="9" value="0.0" />
          <attvalue for="10" value="5" />
        </attvalues>
      </node>
      <node id="doble-clausura" label="Doble clausura">
        <viz:color r="60" g="91" b="107" a="1.0" />
        <viz:size value="13.920011544598458" />
        <attvalues>
          <attvalue for="0" value="cybernetics" />
          <attvalue for="1" value="Cibernetica 2do orden" />
          <attvalue for="2" value="Heinz von Foerster" />
          <attvalue for="3" value="El sistema nervioso opera recursivamente sobre sí mismo en dos sentidos: actúa sobre lo que «ve» (clausura sensoriomotriz) y sobre sus propios operadores (clausura modulatoria, vía sistema endocrino)." />
          <attvalue for="4" value="7" />
          <attvalue for="5" value="10.0" />
          <attvalue for="6" value="0.019600057722992285" />
          <attvalue for="7" value="0.31802120141342755" />
          <attvalue for="8" value="0.04319419501520321" />
          <attvalue for="9" value="0.0" />
          <attvalue for="10" value="5" />
        </attvalues>
      </node>
      <node id="imperativo-etico-constructivista" label="Imperativo ético constructivista">
        <viz:color r="60" g="91" b="107" a="1.0" />
        <viz:size value="13.33025848271497" />
        <attvalues>
          <attvalue for="0" value="cybernetics" />
          <attvalue for="1" value="Cibernetica 2do orden" />
          <attvalue for="2" value="Heinz von Foerster" />
          <attvalue for="3" value="«Actúa siempre de modo de aumentar el número de opciones.» Si yo invento el mundo en que vivo y los otros también lo hacen, la ética debe orientar la acción hacia preservar y multiplicar las posibilidades del otro y las propias." />
          <attvalue for="4" value="5" />
          <attvalue for="5" value="6.0" />
          <attvalue for="6" value="0.016651292413574856" />
          <attvalue for="7" value="0.3125" />
          <attvalue for="8" value="0.056154502487236996" />
          <attvalue for="9" value="0.0" />
          <attvalue for="10" value="5" />
        </attvalues>
      </node>
      <node id="auto-organizacion-kauffman" label="Auto-organización (Kauffman)">
        <viz:color r="184" g="133" b="31" a="1.0" />
        <viz:size value="13.01337461262555" />
        <attvalues>
          <attvalue for="0" value="termodinamica" />
          <attvalue for="1" value="Termodinamica del no-equilibrio" />
          <attvalue for="2" value="Stuart Kauffman" />
          <attvalue for="3" value="Fuente de orden biológica anterior y complementaria a la selección natural: las leyes de la complejidad hacen que ciertos órdenes emerjan espontáneamente en sistemas suficientemente diversos, sin necesidad de explicación adaptativa." />
          <attvalue for="4" value="7" />
          <attvalue for="5" value="10.0" />
          <attvalue for="6" value="0.015066873063127744" />
          <attvalue for="7" value="0.3237410071942446" />
          <attvalue for="8" value="0.07896101865441192" />
          <attvalue for="9" value="0.0" />
          <attvalue for="10" value="4" />
        </attvalues>
      </node>
      <node id="orden-gratis" label="Orden gratis">
        <viz:color r="184" g="133" b="31" a="1.0" />
        <viz:size value="10.0" />
        <attvalues>
          <attvalue for="0" value="termodinamica" />
          <attvalue for="1" value="Termodinamica del no-equilibrio" />
          <attvalue for="2" value="Stuart Kauffman" />
          <attvalue for="3" value="El orden biológico no es solo lo que la selección natural ha cincelado a fuerza de mutaciones favorables: hay un orden que emerge espontáneamente de las dinámicas de redes complejas, sin costo selectivo." />
          <attvalue for="4" value="5" />
          <attvalue for="5" value="9.0" />
          <attvalue for="6" value="0.0" />
          <attvalue for="7" value="0.30201342281879195" />
          <attvalue for="8" value="0.06664065775289414" />
          <attvalue for="9" value="0.0" />
          <attvalue for="10" value="4" />
        </attvalues>
      </node>
      <node id="conjuntos-autocataliticos" label="Conjuntos autocatalíticos">
        <viz:color r="184" g="133" b="31" a="1.0" />
        <viz:size value="11.617513364704376" />
        <attvalues>
          <attvalue for="0" value="termodinamica" />
          <attvalue for="1" value="Termodinamica del no-equilibrio" />
          <attvalue for="2" value="Stuart Kauffman" />
          <attvalue for="3" value="Conjunto de moléculas que catalizan colectivamente la red de reacciones que las produce. Para Kauffman, es el origen químico de la vida: cierre catalítico colectivo, no replicación de una molécula maestra." />
          <attvalue for="4" value="5" />
          <attvalue for="5" value="7.0" />
          <attvalue for="6" value="0.008087566823521878" />
          <attvalue for="7" value="0.29508196721311475" />
          <attvalue for="8" value="0.046354871906155504" />
          <attvalue for="9" value="0.0" />
          <attvalue for="10" value="4" />
        </attvalues>
      </node>
      <node id="borde-del-caos" label="Borde del caos">
        <viz:color r="184" g="133" b="31" a="1.0" />
        <viz:size value="11.362694667216767" />
        <attvalues>
          <attvalue for="0" value="termodinamica" />
          <attvalue for="1" value="Termodinamica del no-equilibrio" />
          <attvalue for="2" value="Stuart Kauffman" />
          <attvalue for="3" value="Régimen de transición entre orden rígido y caos donde el comportamiento complejo prospera: los sistemas adaptativos tienden a sintonizarse en este borde porque allí pueden explorar y persistir a la vez." />
          <attvalue for="4" value="5" />
          <attvalue for="5" value="8.0" />
          <attvalue for="6" value="0.006813473336083831" />
          <attvalue for="7" value="0.3103448275862069" />
          <attvalue for="8" value="0.07242669218145684" />
          <attvalue for="9" value="0.0" />
          <attvalue for="10" value="4" />
        </attvalues>
      </node>
      <node id="redes-booleanas" label="Redes booleanas">
        <viz:color r="184" g="133" b="31" a="1.0" />
        <viz:size value="10.084200305174088" />
        <attvalues>
          <attvalue for="0" value="termodinamica" />
          <attvalue for="1" value="Termodinamica del no-equilibrio" />
          <attvalue for="2" value="Stuart Kauffman" />
          <attvalue for="3" value="Modelo formal de muchos elementos binarios (on/off) con conexiones aleatorias y reglas lógicas. Permite explorar matemáticamente cómo se comportan grandes redes interactuantes y muestra que el orden emerge espontáneamente con baja conectividad (K=2)." />
          <attvalue for="4" value="4" />
          <attvalue for="5" value="6.0" />
          <attvalue for="6" value="0.0004210015258704397" />
          <attvalue for="7" value="0.2535211267605634" />
          <attvalue for="8" value="0.03613670177792737" />
          <attvalue for="9" value="0.0" />
          <attvalue for="10" value="4" />
        </attvalues>
      </node>
      <node id="estructura-disipativa" label="Estructura disipativa">
        <viz:color r="184" g="133" b="31" a="1.0" />
        <viz:size value="14.820007817694531" />
        <attvalues>
          <attvalue for="0" value="termodinamica" />
          <attvalue for="1" value="Termodinamica del no-equilibrio" />
          <attvalue for="2" value="Ilya Prigogine &amp; Isabelle Stengers" />
          <attvalue for="3" value="Forma de organización supramolecular que emerge en sistemas alejados del equilibrio: la disipación de materia y energía, que clásicamente significaba pérdida y desorden, se convierte en fuente de orden." />
          <attvalue for="4" value="7" />
          <attvalue for="5" value="10.0" />
          <attvalue for="6" value="0.02410003908847266" />
          <attvalue for="7" value="0.33707865168539325" />
          <attvalue for="8" value="0.07787012965876655" />
          <attvalue for="9" value="0.0" />
          <attvalue for="10" value="7" />
        </attvalues>
      </node>
      <node id="lejos-del-equilibrio" label="Lejos del equilibrio">
        <viz:color r="184" g="133" b="31" a="1.0" />
        <viz:size value="15.255652467666268" />
        <attvalues>
          <attvalue for="0" value="termodinamica" />
          <attvalue for="1" value="Termodinamica del no-equilibrio" />
          <attvalue for="2" value="Ilya Prigogine &amp; Isabelle Stengers" />
          <attvalue for="3" value="Régimen termodinámico en que el flujo de materia y energía a través del sistema es lo bastante intenso como para mantener al sistema en estados altamente improbables. Solo en este régimen pueden emerger estructuras disipativas." />
          <attvalue for="4" value="7" />
          <attvalue for="5" value="9.0" />
          <attvalue for="6" value="0.02627826233833134" />
          <attvalue for="7" value="0.3358208955223881" />
          <attvalue for="8" value="0.09354961930286167" />
          <attvalue for="9" value="0.0" />
          <attvalue for="10" value="7" />
        </attvalues>
      </node>
      <node id="tiempo-irreversible" label="Tiempo irreversible (flecha del tiempo)">
        <viz:color r="184" g="133" b="31" a="1.0" />
        <viz:size value="10.745153722681813" />
        <attvalues>
          <attvalue for="0" value="termodinamica" />
          <attvalue for="1" value="Termodinamica del no-equilibrio" />
          <attvalue for="2" value="Ilya Prigogine &amp; Isabelle Stengers" />
          <attvalue for="3" value="El tiempo no es solo coordenada reversible de la mecánica clásica: es productor, irreversible, generador. El universo es histórico — la ciencia debe pensar el tiempo como creación, no como ilusión." />
          <attvalue for="4" value="6" />
          <attvalue for="5" value="9.0" />
          <attvalue for="6" value="0.003725768613409063" />
          <attvalue for="7" value="0.28125" />
          <attvalue for="8" value="0.05326327326183708" />
          <attvalue for="9" value="0.0" />
          <attvalue for="10" value="7" />
        </attvalues>
      </node>
      <node id="orden-por-fluctuaciones" label="Orden por fluctuaciones">
        <viz:color r="184" g="133" b="31" a="1.0" />
        <viz:size value="11.463262496970362" />
        <attvalues>
          <attvalue for="0" value="termodinamica" />
          <attvalue for="1" value="Termodinamica del no-equilibrio" />
          <attvalue for="2" value="Ilya Prigogine &amp; Isabelle Stengers" />
          <attvalue for="3" value="Mecanismo por el cual una pequeña fluctuación local, en lugar de promediarse y desaparecer, es amplificada por la dinámica del sistema y produce una nueva estructura macroscópica: la novedad nace del ruido." />
          <attvalue for="4" value="6" />
          <attvalue for="5" value="7.0" />
          <attvalue for="6" value="0.00731631248485181" />
          <attvalue for="7" value="0.2803738317757009" />
          <attvalue for="8" value="0.054291661807243145" />
          <attvalue for="9" value="0.0" />
          <attvalue for="10" value="7" />
        </attvalues>
      </node>
      <node id="la-nueva-alianza" label="La nueva alianza">
        <viz:color r="184" g="133" b="31" a="1.0" />
        <viz:size value="23.591735755207885" />
        <attvalues>
          <attvalue for="0" value="termodinamica" />
          <attvalue for="1" value="Termodinamica del no-equilibrio" />
          <attvalue for="2" value="Ilya Prigogine &amp; Isabelle Stengers" />
          <attvalue for="3" value="Tesis cultural-filosófica del libro: el descubrimiento del tiempo y de la auto-organización por la propia ciencia natural reabre el diálogo, roto desde Galileo, entre las ciencias y la condición humana." />
          <attvalue for="4" value="5" />
          <attvalue for="5" value="6.0" />
          <attvalue for="6" value="0.06795867877603942" />
          <attvalue for="7" value="0.3225806451612903" />
          <attvalue for="8" value="0.0453804818694456" />
          <attvalue for="9" value="0.0" />
          <attvalue for="10" value="7" />
        </attvalues>
      </node>
