        <viz:size value="51.595020119739296" />
        <attvalues>
          <attvalue for="0" value="morin" />
          <attvalue for="1" value="Pensamiento complejo (Morin)" />
          <attvalue for="2" value="Edgar Morin" />
          <attvalue for="3" value="Ser vivo que se autoproduce en relación con su medio, con capacidad de reflexión y autonomía relativa, no reducible a objeto." />
          <attvalue for="4" value="15" />
          <attvalue for="5" value="18.0" />
          <attvalue for="6" value="0.20797510059869648" />
