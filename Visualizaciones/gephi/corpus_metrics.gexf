      <node id="homo-complexus" label="Homo complexus">
        <viz:color r="122" g="46" b="46" a="1.0" />
        <viz:size value="12.403672792084336" />
        <attvalues>
          <attvalue for="0" value="morin" />
          <attvalue for="1" value="Pensamiento complejo (Morin)" />
          <attvalue for="2" value="Edgar Morin" />
          <attvalue for="3" value="Humanidad entendida como síntesis viviente de dimensiones contradictorias: animal-racional, individual-social, consciente-inconsciente." />
          <attvalue for="4" value="9" />
          <attvalue for="5" value="14.0" />
          <attvalue for="6" value="0.012018363960421677" />
