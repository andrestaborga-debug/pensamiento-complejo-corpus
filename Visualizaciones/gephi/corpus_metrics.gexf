          <attvalue for="1" value="Pensamiento complejo (Morin)" />
          <attvalue for="2" value="Edgar Morin" />
          <attvalue for="3" value="Incapacidad constitutiva de la mente para ver lo que la estructura de nuestro pensamiento oculta sistemáticamente." />
          <attvalue for="4" value="5" />
